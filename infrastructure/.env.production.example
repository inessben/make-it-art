POSTGRES_DB=makeitart
POSTGRES_USER=mia
POSTGRES_PASSWORD=change_this_database_password

JWT_SECRET=change_this_to_a_long_random_secret
APP_BASE_URL=https://www.makeitart.io
CORS_ORIGIN=https://www.makeitart.io
NUXT_PUBLIC_API_BASE=/api

SESSION_COOKIE_NAME=mia_session
REFRESH_COOKIE_NAME=mia_refresh
LOGIN_CODE_COOKIE_NAME=mia_login_challenge
REMEMBER_DEVICE_COOKIE_NAME=mia_remember_device

SMTP_HOST=smtp.your-provider.tld
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=Make It Art <no-reply@makeitart.io>

NPM_REGISTRY=https://registry.npmjs.org
