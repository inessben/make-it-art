makeitart.io {
  redir https://www.makeitart.io{uri} permanent
}

www.makeitart.io {
  encode zstd gzip

  header {
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    Referrer-Policy strict-origin-when-cross-origin
  }

  handle /api/* {
    reverse_proxy backend:4000
  }

  handle {
    reverse_proxy frontend:3000
  }
}
