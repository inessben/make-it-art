generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model user {
  id              Int       @id
  username        String?   @db.VarChar
  email           String?   @db.VarChar
  password_hash   String?
  role            String?   @db.VarChar
  created_at      DateTime? @db.Timestamp(6)
  bio             String?
  is_active       Boolean?
  wallet_addresse String?
  verified        Boolean?
  phone           String?   @db.VarChar
}
